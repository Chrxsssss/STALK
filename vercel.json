{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/", "dest": "/api/index.py" },
    { "src": "/bot", "dest": "/api/bot.py" },
    { "src": "/stream", "dest": "/api/stream.py" },
    { "src": "/victim/(?P<id>[^/]+)", "dest": "/api/victim/[id].py" }
  ]
}
